{
  "name": "@actalk/inkos-studio",
  "version": "1.4.1",
  "description": "InkOS Studio — Web workbench for novel writing",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/Narcooo/inkos.git",
    "directory": "packages/studio"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "type": "module",
  "main": "dist/api/index.js",
  "types": "dist/api/index.d.ts",
  "scripts": {
    "prepack": "npm run build && node ../../scripts/prepare-package-for-publish.mjs",
    "postpack": "node ../../scripts/restore-package-json.mjs",
    "prepublishOnly": "node ../../scripts/verify-no-workspace-protocol.mjs .",
    "dev": "concurrently --kill-others \"cross-env INKOS_STUDIO_PORT=4569 INKOS_PROJECT_ROOT=../.. tsx watch --clear-screen=false src/api/index.ts\" \"vite --host --port 4567\" ",
    "dev:client": "vite --host --port 4567",
    "dev:server": "INKOS_STUDIO_PORT=4569 INKOS_PROJECT_ROOT=../.. tsx watch src/api/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@actalk/inkos-core": "workspace:*",
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.9",
    "@hono/node-server": "^2.0.3",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "ai": "^6.0.185",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "hono": "^4.12.19",
    "lucide-react": "^1.16.0",
    "motion": "^12.39.0",
    "nanoid": "^5.1.11",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.7.0",
    "shiki": "^4.0.2",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260519.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.2",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
