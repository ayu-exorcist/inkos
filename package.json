{
  "name": "inkos",
  "version": "1.4.1",
  "private": true,
  "description": "Autonomous AI novel writing CLI agent — 10-agent pipeline that writes, audits, and revises novels with continuity tracking",
  "keywords": [
    "ai-novel-writing",
    "ai-writing-agent",
    "novel-generator",
    "autonomous-writing",
    "litrpg",
    "progression-fantasy",
    "multi-agent",
    "creative-writing-ai",
    "openclaw-skill",
    "cli"
  ],
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/Narcooo/inkos"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "lint": "oxlint -c .oxlintrc.json packages",
    "lint:fix": "oxlint -c .oxlintrc.json packages --fix",
    "format": "oxfmt packages",
    "format:check": "oxfmt --check packages",
    "typecheck": "pnpm -r typecheck",
    "verify:publish-manifests": "node scripts/verify-no-workspace-protocol.mjs packages/core packages/cli packages/studio",
    "release": "pnpm build && pnpm test && pnpm lint"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "typescript": "^6.0.3"
  }
}
